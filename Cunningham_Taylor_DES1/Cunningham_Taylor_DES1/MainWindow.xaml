<Window x:Class="Cunningham_Taylor_DES1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cunningham_Taylor_DES1"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="100"/>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label Content="Input (ASCII): " Grid.Row="0" Grid.Column="0"/>
        <Label Content="Output (Binary with append): " Grid.Row="1" Grid.Column="0"/>
        <Label Content="PC-1 Permutation: " Grid.Row="2" Grid.Column="0"/>
        <TextBox x:Name="txtASCII" Grid.Row ="0" Grid.Column="1" Margin="10" TextWrapping="Wrap" TextChanged="txtASCII_TextChanged"/>
        <TextBox x:Name="txtBinary" Grid.Row ="1" Grid.Column="1" Margin="10" TextWrapping="Wrap"/>
        <TextBox x:Name="txtPC1" Grid.Row ="2" Grid.Column="1" Margin="10" TextWrapping="Wrap"/>
    </Grid>
</Window>
