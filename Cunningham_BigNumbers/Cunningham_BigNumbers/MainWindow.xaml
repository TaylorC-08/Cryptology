<Window x:Class="Cunningham_BigNumbers.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cunningham_BigNumbers"
        mc:Ignorable="d"
        Title="Big Numbers" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="100"/>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="75"/>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Label Content="Number 1:" Grid.Row="0" Grid.Column="0"/>
        <Label Content="Number 2:" Grid.Row="1" Grid.Column="0"/>
        <TextBox x:Name="txtNum1" Grid.Row="0" Grid.Column="1" Margin="10" Grid.ColumnSpan="2" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
        <TextBox x:Name="txtNum2" Grid.Row="1" Grid.Column="1" Margin="10" Grid.ColumnSpan="2" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
        <Button x:Name="cmdAdd" Grid.Row="2" Grid.Column="1" Margin="10" Content="Add" Click="cmdAdd_Click"/>
        <Button x:Name="cmdMult" Grid.Row="2" Grid.Column="2" Margin="10" Content="Multiply" Click="cmdMult_Click"/>
        <Label Content="Output:" Grid.Row="3" Grid.Column="0"/>
        <TextBox x:Name="txtOut" Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="3" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="10"/>

    </Grid>
</Window>
