<Window x:Class="Cunningham_Taylor_27.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cunningham_Taylor_27"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="175"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label Content="Input 128 bit cipher key:" Grid.Row="0" Grid.Column="0" Margin="10"/>
        <TextBox x:Name="txtInput" Grid.Column="1" Grid.Row="0" Margin="10" TextChanged="txtInput_TextChanged" PreviewTextInput="txtInput_PreviewTextInput" />
        <Label Content="Output:" Grid.Row="1" Grid.Column="0" Margin="10"/>
        <TextBox x:Name="txtOutput" Grid.Row="1" Grid.Column="1" Margin="10" TextWrapping="Wrap"/>
    </Grid>
</Window>
