<Window x:Class="Cunningham_Taylor_NIST_Randomness.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Cunningham_Taylor_NIST_Randomness"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="120"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label Grid.Column="0" Grid.Row="0" Content="Input (in hex):"/>
        <Label Grid.Column="0" Grid.Row="1" Content="Input (in Binary):"/>
        <Label Grid.Column="0" Grid.Row="2" Content="M value (type this first or else):"/>
        <Label Grid.Column="0" Grid.Row="3" Content="p value (monobits):"/>
        <Label Grid.Column="0" Grid.Row="4" Content="p value (Blocks):"/>
        <TextBox Grid.Column ="1" Grid.Row="0" x:Name="txtHex" Margin="10" TextChanged="txtHex_TextChanged" PreviewTextInput="txtHex_PreviewTextInput"/>
        <TextBox Grid.Column="1" Grid.Row="1" x:Name="txtBinary" Margin="10" TextChanged="txtBinary_TextChanged" PreviewTextInput="txtBinary_PreviewTextInput"/>
        <TextBox Grid.Column="1" Grid.Row="2" x:Name="txtM" Margin="10"/>
        <TextBox Grid.Column="1" Grid.Row="3" x:Name="txtPvalue" Margin="10"/>
        <TextBox Grid.Column="1" Grid.Row="4" x:Name="txtPvalueBlocks" Margin="10"/>
    </Grid>
</Window>
