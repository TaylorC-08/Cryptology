<Window x:Class="Index_of_Coincidence.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Index_of_Coincidence"
        mc:Ignorable="d"
        Title="Index of Coincidence" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="50"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="10"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="10"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
        </Grid.RowDefinitions>
        <Label Content="Cipher Text:" Grid.Row="1" Grid.Column="1"/>
        <Label Content="Test Period:" Grid.Row="7" Grid.Column="1"/>
        <Label x:Name="txtError" Grid.Row="7" Grid.Column="7" Content=""/>
        <TextBox x:Name="txtPeriod" Grid.Column="3" Grid.Row="7" Text="" TextChanged="txtPeriod_TextChanged"/>
        <TextBox x:Name="txtIoC" Grid.Column="5" Grid.ColumnSpan="3" Grid.Row="5" Text="" Margin="0,0,450,0" />
        <Label Grid.Column="1" Grid.ColumnSpan="3" Grid.Row="5" Content="Index of Coincidence:"/>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Column="1" Grid.ColumnSpan="7" Grid.Row="3">
            <TextBox x:Name="txtCipher" TextWrapping="Wrap" Text="" TextChanged="txtCipher_TextChanged"/>
        </ScrollViewer>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Column="1" Grid.ColumnSpan="7" Grid.Row="9">
            <TextBox x:Name="txtIndexes" TextWrapping="Wrap" Text=""/>
        </ScrollViewer>
    </Grid>
</Window>
